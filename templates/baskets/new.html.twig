{% extends 'base.html.twig' %}

{% block title %}New Basket{% endblock %}

{% block body %}
    <div class="w-full max-w-screen-sm mx-auto px-4">
        <div class="flex justify-between items-center">
            <h1 class="text-2xl my-8 text-gray-900 dark:text-white font-bold">New basket</h1>
            <a href="{{ path('baskets') }}" class="flex items-center gap-1 hover:cursor-pointer">
                Go back
                <img alt src="{{ asset('build/icons/arrow-long-right.svg') }}" class="w-6 h-6 ml-2">
            </a>
        </div>

        {{ form_start(form) }}
        <div class="space-y-12">
            <div class="border-b border-gray-900/10 pb-12 dark:border-white/10">
                <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">Basket Details</h2>
                <p class="mt-1 text-sm/6 text-gray-600 dark:text-gray-400">Give your basket a name to easily identify it
                    later.</p>

                <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">
                    <div class="sm:col-span-4">
                        {{ form_label(form.name, 'Basket Name', {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900 dark:text-white'}}) }}
                        <div class="mt-2">
                            {{ form_widget(form.name, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500', 'placeholder': 'e.g. Weekly Groceries'}}) }}
                        </div>
                        {{ form_errors(form.name, {'attr': {'class': 'mt-2 text-sm text-red-600 dark:text-red-400'}}) }}
                    </div>

                    <div class="col-span-full" {{ stimulus_controller('basket-items-collection') }}>
                        <ul class="space-y-4"
                            data-basket-items-collection-target="list"
                            data-index="{{ form.items|length > 0 ? form.items|last.vars.name + 1 : 0 }}"
                            data-prototype="{{ _self.render_item(form.items.vars.prototype, true)|e('html_attr') }}"
                        >
                            {% for item in form.items %}
                                <li class="relative flex gap-x-4 rounded-xl p-4 ring-1 ring-inset ring-gray-200 dark:ring-white/10 bg-gray-50 dark:bg-white/5">
                                    {{ _self.render_item(item, true) }}
                                </li>
                            {% endfor %}
                        </ul>

                        <div class="mt-6 flex items-center gap-x-3">
                            <button type="button"
                                    class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:bg-white/10 dark:text-white dark:shadow-none dark:ring-white/5 dark:hover:bg-white/20 flex items-center gap-x-2"
                                    data-action="basket-items-collection#add">
                                <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor"
                                     aria-hidden="true">
                                    <path
                                        d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"/>
                                </svg>
                                Add an item
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-6 flex items-center justify-end gap-x-6">
            <a href="{{ path('baskets') }}" class="text-sm/6 font-semibold text-gray-900 dark:text-white">Cancel</a>
            {{ form_widget(form.save, {
                'label': 'Save Basket',
                'attr': {'class': 'rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:focus-visible:outline-indigo-500'}
            }) }}
        </div>

        {# Render CSRF token and other hidden fields #}
        {{ form_rest(form) }}
        {{ form_end(form) }}
    </div>
{% endblock %}

{% macro render_item(item, include_remove = false) %}
    <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6 flex-1">
        <div class="sm:col-span-3">
            {{ form_label(item.product, null, {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900 dark:text-white'}}) }}
            <div class="mt-2 grid grid-cols-1">
                {{ form_widget(item.product, {'attr': {'class': 'col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-1.5 pr-8 pl-3 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:*:bg-gray-800 dark:focus:outline-indigo-500'}}) }}
                <svg viewBox="0 0 16 16" fill="currentColor" data-slot="icon" aria-hidden="true"
                     class="pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end text-gray-500 sm:size-4 dark:text-gray-400">
                    <path
                        d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z"
                        clip-rule="evenodd" fill-rule="evenodd"/>
                </svg>
            </div>
            {{ form_errors(item.product) }}
        </div>
        <div class="sm:col-span-1">
            {{ form_label(item.amount, null, {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900 dark:text-white'}}) }}
            <div class="mt-2">
                {{ form_widget(item.amount, {'attr': {'class': 'block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500', 'placeholder': '0.00'}}) }}
            </div>
            {{ form_errors(item.amount) }}
        </div>
        <div class="sm:col-span-2">
            {{ form_label(item.unit, null, {'label_attr': {'class': 'block text-sm/6 font-medium text-gray-900 dark:text-white'}}) }}
            <div class="mt-2 grid grid-cols-1">
                {{ form_widget(item.unit, {'attr': {'class': 'col-start-1 row-start-1 w-full appearance-none rounded-md bg-white py-1.5 pr-8 pl-3 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:*:bg-gray-800 dark:focus:outline-indigo-500'}}) }}
                <svg viewBox="0 0 16 16" fill="currentColor" data-slot="icon" aria-hidden="true"
                     class="pointer-events-none col-start-1 row-start-1 mr-2 size-5 self-center justify-self-end text-gray-500 sm:size-4 dark:text-gray-400">
                    <path
                        d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z"
                        clip-rule="evenodd" fill-rule="evenodd"/>
                </svg>
            </div>
            {{ form_errors(item.unit) }}
        </div>
    </div>

    {% if include_remove %}
        <button type="button"
                class="absolute -top-2 -right-2 rounded-full bg-red-600 p-1 text-white shadow-sm hover:bg-red-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-600"
                data-action="basket-items-collection#remove">
            <span class="sr-only">Remove item</span>
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path
                    d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
            </svg>
        </button>
    {% endif %}
{% endmacro %}

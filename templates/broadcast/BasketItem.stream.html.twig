{# templates/broadcast/BasketItem.stream.html.twig #}

{% block create %}
    <turbo-stream action="append" target="basket-item-list">
        <template>
            {% include 'baskets/_basket_item_row.html.twig' with {item: entity, basket: entity.basket} %}
        </template>
    </turbo-stream>
{% endblock %}

{% block update %}
    <turbo-stream action="replace" target="basket-item-{{ id }}">
        <template>
            {% include 'baskets/_basket_item_row.html.twig' with {item: entity, basket: entity.basket} %}
        </template>
    </turbo-stream>
{% endblock %}

{% block remove %}
    <turbo-stream action="remove" target="basket-item-{{ id }}"></turbo-stream>
{% endblock %}
